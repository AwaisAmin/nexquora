generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  service   String
  budget    String?
  message   String
  role      String?
  read      Boolean   @default(false)
  replied   Boolean   @default(false)
  repliedAt DateTime? @map("replied_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("contacts")
}

model Job {
  id           String        @id @default(uuid())
  title        String
  department   String
  type         String
  location     String
  salary       String
  description  String
  requirements String[]
  niceToHave   String[]      @map("nice_to_have")
  published    Boolean       @default(false)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  applications Application[]

  @@map("jobs")
}

model Application {
  id        String   @id @default(uuid())
  jobId     String?  @map("job_id")
  jobTitle  String   @map("job_title")
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@map("applications")
}

model Service {
  id              String   @id @default(uuid())
  slug            String
  title           String
  tagline         String
  description     String
  longDescription String   @map("long_description")
  icon            String
  accentHex       String   @map("accent_hex")
  features        String[]
  tools           String[]
  faq             Json     @default("[]")
  caseStudyTeaser String?  @map("case_study_teaser")
  published       Boolean  @default(true)
  order           Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("services")
}